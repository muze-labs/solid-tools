{
  "name": "@muze-labs/jsfs-solid",
  "version": "0.1.0",
  "type": "module",
  "description": "A JSFS adapter for Solid storage, implemented on top of Lading.",
  "main": "src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./adapter": "./src/SolidAdapter.js",
    "./browser": "./src/browser.js"
  },
  "source": "src/index.mjs",
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "build-dev": "esbuild --bundle src/browser.js --outfile=dist/browser.js --sourcemap",
    "build": "esbuild --bundle src/browser.js --outfile=dist/browser.min.js --minify --sourcemap"
  },
  "keywords": [
    "solid",
    "jsfs",
    "pod",
    "muze"
  ],
  "license": "MIT",
  "dependencies": {
    "@muze-labs/lading": "0.1.0",
    "@muze-nl/jsfs": "^0.3.5",
    "@muze-nl/metro": "^0.8.0",
    "@muze-nl/metro-oauth2": "^0.8.2",
    "@muze-nl/metro-oidc": "^0.6.0",
    "@muze-nl/metro-oldm": "^0.4.0"
  }
}
