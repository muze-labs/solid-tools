{
  "name": "@muze-labs/solid-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Solid and linked-data runtime tools for SimplySolid.",
  "packageManager": "npm@10",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "node scripts/check-workspace.mjs",
    "test": "node --test packages/*/test/*.test.mjs examples/*/test/*.test.mjs",
    "check": "npm run build && npm test",
    "lint": "eslint ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muze-labs/solid-tools.git"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "solid",
    "linked-data",
    "simplysolid",
    "simplyflow",
    "oldm",
    "muze"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.2",
    "globals": "^16.5.0"
  }
}
